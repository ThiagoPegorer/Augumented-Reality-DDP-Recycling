# ============================================================
# AR_DPP_VCU — .gitignore
# Covers Unity 6 LTS project at repo root + Python backend/
# ============================================================

# --- Unity generated folders (never commit) ---
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Uu]serSettings/

# Burst debug info (regenerated on build)
*_BurstDebugInformation_DoNotShip/
*_BackUpThisFolder_ButDontShipItWithYourGame/

# --- Unity-generated project files (regenerated by IDE/Unity) ---
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# --- Unity asset meta files for ignored content ---
sysinfo.txt

# --- Builds & packaged artifacts ---
*.apk
*.aab
*.unitypackage
*.app
ExportedObj/
.consulo/

# --- Crashlytics / Asset Store / Visual Studio for Mac ---
crashlytics-build.properties
/[Aa]ssets/[Aa]ssetStoreTools*
/[Aa]ssets/Plugins/Editor/JetBrains*

# --- Signing / keystore (NEVER commit) ---
*.keystore
*.jks
*.p12
*.pfx

# --- IDE / editor noise ---
.vs/
.vscode/
.idea/
*.swp
*.swo

# --- Python backend ---
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.env
.env.local

# --- OS noise ---
.DS_Store
Thumbs.db
desktop.ini

# --- OneDrive / sync artifacts (just in case) ---
*.tmp.driveupload
*.tmp.drivedownload
